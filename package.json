{
  "name": "funny-error-sounds",
  "displayName": "Funny Error Sounds",
  "description": "Plays hilarious funny sounds when terminal commands fail. Desi meme sounds included! 🔊",
  "version": "1.0.7",
  "publisher": "MayurDhavan",
  "repository": {
    "type": "git",
    "url": "https://github.com/mayur-dhavan/funny-error-sounds-vscode"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "funny",
    "sounds",
    "terminal",
    "error",
    "meme",
    "desi",
    "comedy"
  ],
  "icon": "images/icon.jpg",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "funnyErrorSounds.testSound",
        "title": "Funny Sounds: Play Test Sound 🔊"
      },
      {
        "command": "funnyErrorSounds.toggle",
        "title": "Funny Sounds: Toggle On/Off"
      },
      {
        "command": "funnyErrorSounds.chooseSound",
        "title": "Funny Sounds: Choose Sound Effect 🎵"
      },
      {
        "command": "funnyErrorSounds.uploadCustomSound",
        "title": "Funny Sounds: Upload Custom Sound File 📂"
      }
    ],
    "configuration": {
      "title": "Funny Error Sounds",
      "properties": {
        "funnyErrorSounds.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable funny error sounds."
        },
        "funnyErrorSounds.soundDuration": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 30,
          "description": "How many seconds to play each sound clip (default: 5)."
        },
        "funnyErrorSounds.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification with the sound name when it plays."
        },
        "funnyErrorSounds.soundMode": {
          "type": "string",
          "default": "random",
          "enum": [
            "random",
            "selected",
            "custom"
          ],
          "enumDescriptions": [
            "Play a random sound on each error",
            "Always play the chosen built-in sound",
            "Always play your own uploaded audio file"
          ],
          "description": "Whether to play a random sound, a specific chosen sound, or your own custom audio file."
        },
        "funnyErrorSounds.selectedSound": {
          "type": "string",
          "default": "",
          "description": "The filename of the chosen sound (used when soundMode is 'selected')."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "typescript": "^5.3.0"
  }
}
